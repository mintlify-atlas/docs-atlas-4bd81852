  "keyFeatures": [
    "PNG image file parsing and manipulation",
    "Steganography: Hide and extract secret messages in PNG images",
    "Image overlay: Composite multiple PNG images",
    "LZ77 compression and decompression",
    "Huffman coding with fixed and dynamic trees",
    "GZIP (DEFLATE/INFLATE) algorithm implementation",
    "CRC-32 checksum validation",
    "Low-level C programming with bitwise operations"
  ],
  "publicApiSurface": [
    "png_open() - Open and validate PNG file",
    "png_read_chunk() - Read PNG chunk with CRC validation",
    "png_parse_ihdr() - Parse IHDR header chunk",
    "png_parse_plte() - Parse palette chunk",
    "png_crc() - Compute CRC-32 checksum",
    "png_embed_lsb() - Encode steganographic message",
    "png_extract_lsb() - Extract hidden message",
    "png_overlay_paste() - Overlay images",
    "lz_compress_tokens() - LZ77 compression",
    "huffman_encode_tokens() - Huffman encoding",
    "huffman_decode() - Huffman decoding with LZ77",
    "deflate() - GZIP compression",
    "inflate() - GZIP decompression"
  ]
}
